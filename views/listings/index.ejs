<% layout("/layouts/boilerplate") %>

<style>
    #filters{
        display:flex;
        flex-wrap:wrap;
        align-items:center;
        /* justify-content:space-between; */
        /* justify-content:center; */
    }
    .filter{
        text-align :center;
        opacity:0.7;
        margin-right:2rem;
        margin-top:2rem;
        margin-bottom:2rem;
    }
    .filter:hover{
        opacity:1;
        cursor:pointer;

    }
    .filter p{
        font-size:0.8rem;
    }

    .taxes{
        display:none;
    }

    .toggle-switch{
        border: 2px black solid;
      
        padding:1rem;
        height:3.15rem;
        display:flex;
        flex-wrap:wrap;
       align-items:center;
        
        margin-left:3rem; 
      
         border-radius:0.5rem;
        


    }
   
</style>

<div id="filters">
    <div class="filter">
        <i class="fa-solid fa-fire"></i>
        <p>Trending</p>
    </div>

    <div class="filter">
        <i class="fa-solid fa-bed"></i>
        <p>Rooms</p>
    </div>
    <div class="filter">
        <i class="fa-solid fa-fire"></i>
        <p>Iconic Cities</p>
    </div>

    <div class="filter">
        <i class="fa-solid fa-mountain"></i>
        <p>Mountains</p>
    </div>
    <div class="filter">
        <i class="fa-solid fa-fire"></i>
        <p>Castles</p>
    </div>

    <div class="filter">
        <i class="fa-solid fa-person-swimming"></i>
        <p>Amazing Pools</p>
        
    </div>
    <div class="filter">
        <i class="fa-solid fa-fire"></i>
        <p>Trending</p>
    </div>

    <div class="filter">
        <i class="fa-solid fa-bed"></i>
        <p>Rooms</p>
    </div>
    <div class="filter">
        <i class="fa-solid fa-fire"></i>
        <p>Iconic Cities</p>
    </div>

    <div class="filter">
        <i class="fa-solid fa-mountain"></i>
        <p>Mountains</p>
    </div>
   


  <div class="toggle-switch">
    <div class="form-check-reverse form-switch ">
  <input class="form-check-input" type="checkbox" role="switch" id="flexSwitchCheckDefault">
  <label class="form-check-label" for="flexSwitchCheckDefault">Display after total taxes</label>
</div>
</div>

</div>



    <h3>All &nbsp;Listings</h3>
    <!--<form method="get" action="/listings/new">
        <button> Create a new listing</button>
    </form> ~!-->
    <div class="row row-cols-lg-3 row-cols-md-2 row-cols-sm-1 ">
        <% for(listing of allListings){%>
            <a href="/listings/<%=listing._id%>" class="card-link">
        <div class="card cols listing-card ">
  <img src="<%=listing.image.url%>" class="card-img-top" alt="listing_image" style="height:20rem;">
  <div class="card-img-overlay"></div>
  <div class="card-body">
    <p class="card-text"><b><%=listing.title%></b>
    <br>
   &#x20b9; <%=listing.price.toLocaleString("en-IN")%> &nbsp &nbsp
<i class="taxes"> +18% GST</i></p>
   
  </div>
</div>
</a>
<%} %>
</div>

<script>
    let taxCheck = document.getElementById("flexSwitchCheckDefault")

    taxCheck.addEventListener("click",()=>{
        console.log("clicked");
        let taxes = document.getElementsByClassName("taxes");
        // console.log(taxes);
        for(tax of taxes){
            console.log(tax);
            if(tax.style.display != "inline"){
                tax.style.display = "inline";
            } else{
                tax.style.display = "none";
            }
        }
    })


</script>


