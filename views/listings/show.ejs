<% layout("/layouts/boilerplate") %>





<script>const token = "<%= process.env.MAP_API_KEY%>"
  const listing = <%- JSON.stringify(listing) %>;</script>


<div class="row"></div>
<div class="card listing-card">
    <div class="col-6 offset-3">
    <h3 class="my-3"><b><%=listing.title%></b></h3>
    <img src="<%=listing.image.url%>" class="card-img-top show-img" alt="listing_image">
    </div>

    <div class="card-text mt-3 col-6  offset-3">
        <br>
        <ul>
            <li>Owned By :<i><%=listing.owner.username%></i></li>
        <li><%=listing.description%></li>
        <li>&#x20b9; <%=listing.price.toLocaleString("en-IN")%></li>
        <li><%=listing.
        location%></li>
        <li><%=listing.country%></li>
        </ul>
        </div>
        <%if(currUser && currUser._id.equals(listing.owner._id)){%>
        <div class="btns col-6 offset-3 ">
       
            <form method="get" action= "/listings/<%=listing._id%>/edit" >
        <button class="btn btn-dark listing-btn ">Edit</button>
        </form>
        <br><br>
        <form method="POST" action="/listings/<%=listing._id%>?_method=DELETE">
        <button class="btn btn-dark btn-delete offset-4">Delete</button>
        </form>
        
         
        </div>
        <%}%>
    </div>
</div>  
    </form>
   
    <div class="col-6 offset-3">
      
         <%if(currUser){%>
    <form method="POST" action="/listings/<%=listing._id%>/reviews" novalidate class="needs-validation">
        <h4 class="my-3">Leave a review:</h4>
        <label for="rating" class="form-label">Rate:</label>

        <input type="range" id="rating" name="review[rating]" class=" form-range " min="1" max="5"/>


        <label for="comment" class="form-label">Comment</label>

        <textarea id="comment" name="review[comment]" rows="5" col="30" class="form-control" required></textarea>
        <div class="invalid-feedback">Please submit some comments for review</div>

         <button class="btn btn-outline-dark my-3 ">Submit</button>
    </form>
     <%}%>
    <hr>
    <%if(listing.reviews.length > 0){%>
    <p><b>All Reviews</b></p>
    <div class="row">
   <% for(review of listing.reviews){%>
        <div class="card col-5 ms-3 mb-3">
            <div class="card-body">
                <h5 class="card-title ms-2"><%=review.author.username%></h5>
                <p class="starability-result card-text" data-rating="<%=review.rating%>">
                 Rated: 3 stars
                 </p>
                <p class="card-text ms-2"><%=review.comment%></p>
                 
                <form method="POST" action="/listings/<%=listing._id%>/reviews/<%=review._id%>?_method=DELETE">
            <button class="btn btn-dark btn-sm mb-2">DELETE</button>
        </form>
            </div>
        </div>
   <% }%>
   </div>
   <%}%>
   <h4>Where you will be @</h4>
    
   <div id="map" style="width:80%; height:400px;"></div>

    <script src="https://unpkg.com/maplibre-gl@3.6.2/dist/maplibre-gl.js"></script>

   <script type="module" src="/js/map.js"></script>
   <br>
    </div>

