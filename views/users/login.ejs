<% layout("/layouts/boilerplate") %>
<div class="row mt-3">
    <h1 class="col-6 offset-3 mb-3">Login</h1>
    <form class="col-6 offset-3 needs-validation" action="/login" method="POST" novalidate >
        <div class="mb-3">
            <label for="username" class="form-label">Username</label>
            <input
            id="username"
            name="username"
            class="form-control"
            type="text"
            required/>

        </div>
        <div class="mb-3">
              <label for="password" class="form-label">Password</label>
            <input
            id="password"
            name="password"
            class="form-control"
            type="password"
            required/>

        </div>
        <button class="btn btn-success ">Login</button>

    </form>

</div>
